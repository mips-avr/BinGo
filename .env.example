# ==============================================
# BinGo — Contoh variabel lingkungan (Phase 1)
# Salin ke .env (root) lalu sesuaikan nilainya.
# ==============================================

# ---- Database (Postgres + PostGIS lokal via docker-compose) ----
POSTGRES_USER=bingo
POSTGRES_PASSWORD=bingo_dev_password
POSTGRES_DB=bingo
POSTGRES_PORT=5432

# DATABASE_URL dipakai oleh Prisma di apps/backend
DATABASE_URL="postgresql://bingo:bingo_dev_password@localhost:5432/bingo?schema=public"

# ---- Backend (NestJS) ----
BACKEND_PORT=3000
NODE_ENV=development
JWT_SECRET=ganti_dengan_secret_acak_panjang_minimal_32_karakter
JWT_EXPIRES_IN=7d

# ---- Mobile (Expo) ----
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
