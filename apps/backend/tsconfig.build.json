{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    // Saat build produksi, abaikan path mapping ke source shared packages —
    // tsc akan resolve via pnpm workspace symlinks ke dist masing-masing.
    "paths": {}
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "test", "dist", "prisma", "**/*spec.ts", "**/__tests__/**"]
}
