{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@bingo/shared-types": ["../../packages/shared-types/src"],
      "@bingo/shared-utils": ["../../packages/shared-utils/src"],
      "@bingo/i18n": ["../../packages/i18n/src"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}
